{
  "name": "long-watch",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "First-person voxel D&D one-shot — defend the Heir until dawn.",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format": "prettier --write \"src/**/*.{ts,js}\" \"tests/**/*.ts\""
  },
  "dependencies": {
    "@types/seedrandom": "^3.0.8",
    "cannon-es": "^0.20.0",
    "dice-typescript": "^1.6.1",
    "fantastical": "^2.0.1",
    "labyrinthos": "^1.1.2",
    "replicate": "^1.4.0",
    "rot-js": "^2.2.1",
    "seedrandom": "^3.0.5",
    "three": "^0.177.0",
    "threejs-vox-loader": "^2.0.0",
    "tone": "^15.1.22",
    "trystero": "^0.24.0",
    "xstate": "^5.31.1"
  },
  "devDependencies": {
    "@types/three": "^0.170.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitest/ui": "^4.1.6",
    "eslint": "^10.4.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.6"
  }
